# ─── DATABASE ───────────────────────────────────────────────
# Local development (Docker):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/creator_os_dev
# Railway production (paste from Railway dashboard):
# DATABASE_URL=postgresql://postgres:PASSWORD@containers-us-west-XX.railway.app:PORT/railway

# ─── REDIS ──────────────────────────────────────────────────
# Local development (Docker):
REDIS_URL=redis://localhost:6379
# Railway production:
# REDIS_URL=redis://default:PASSWORD@containers-us-west-XX.railway.app:PORT

# ─── SERVER ─────────────────────────────────────────────────
# Port the Go HTTP server listens on
PORT=8080
# development or production — changes logging behavior, error detail
ENVIRONMENT=development
# Frontend URL — used for CORS allowlist
FRONTEND_URL=http://localhost:3000

# ─── AUTH ───────────────────────────────────────────────────
# JWT signing secret — MUST be at least 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_32_char_minimum_string
# Access token expires in 15 minutes (short = more secure)
JWT_ACCESS_EXPIRY_MINUTES=15
# Refresh token expires in 7 days
JWT_REFRESH_EXPIRY_DAYS=7

# ─── STRIPE ─────────────────────────────────────────────────
# Test mode keys from Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
# Created when you set up webhooks (Day 3)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# ─── EMAIL ──────────────────────────────────────────────────
# From Resend dashboard → API Keys
RESEND_API_KEY=re_YOUR_KEY_HERE
# The "from" address for emails (test domain works for demo)
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=CreatorOS

# ─── AI ─────────────────────────────────────────────────────
# From Groq console → API Keys
GROQ_API_KEY=gsk_YOUR_KEY_HERE
# Model to use for text generation
GROQ_MODEL=llama-3.1-70b-versatile
# Monthly cost limit — circuit breaker stops AI calls if exceeded
# Groq is free so set high, change to $50 if you add OpenAI later
AI_MONTHLY_COST_LIMIT_USD=10

# ─── STORAGE ────────────────────────────────────────────────
# From Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── MONITORING ─────────────────────────────────────────────
# From Sentry dashboard → Settings → Projects → creator-os-backend → Client Keys
SENTRY_DSN=https://abc123@o123456.ingest.sentry.io/789012