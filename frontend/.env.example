# ─── API ────────────────────────────────────────────────────
# Local Go backend URL
REACT_APP_API_URL=http://localhost:8080
# GraphQL endpoint (Go backend serves this path)
REACT_APP_GRAPHQL_URL=http://localhost:8080/query

# ─── STRIPE ─────────────────────────────────────────────────
# Publishable key (safe to expose in frontend)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# ─── MONITORING ─────────────────────────────────────────────
# From Sentry dashboard → creator-os-frontend project → Client Keys
REACT_APP_SENTRY_DSN=https://xyz789@o123456.ingest.sentry.io/345678

# ─── APP ────────────────────────────────────────────────────
REACT_APP_NAME=CreatorOS
REACT_APP_VERSION=0.1.0